<h1>Delete Book</h1>

<p>Are you sure you want to delete this book?</p>

<%= render @book %>

<div class="mt-3">
  <%= button_to "Yes, delete this book",
                @book,
                method: :delete,
                form: { data: { turbo_confirm: "This cannot be undone. Proceed?" } } %>

  <%= link_to "Cancel", book_path(@book), style: "margin-left: 1rem" %>
  |
  <%= link_to "Back to Home", books_path %>
</div>
