<div id="<%= dom_id(book) %>">
  <p><strong>Title:</strong> <%= book.title %></p>
  <p><strong>Author:</strong> <%= book.author %></p>
  <p><strong>Price:</strong> <%= number_to_currency(book.price) if book.price.present? %></p>
  <p><strong>Published date:</strong> <%= book.published_date %></p>
</div>
