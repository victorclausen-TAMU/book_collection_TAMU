{
  "stack": "heroku-24",
  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "heroku/ruby" }
  ],
  "environments": {
    "review": {
      "addons": [ "heroku-postgresql" ],
      "scripts": { "postdeploy": "bundle exec rails db:schema:load" },
      "env": {
        "RAILS_ENV": "review",
        "DISABLE_DATABASE_ENVIRONMENT_CHECK": "1"
      }
    }
  }
}
